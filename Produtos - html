<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Masmorra de Itens | Catálogo Taverna Geek</title>
  <meta name="description" content="Explore a masmorra de itens da Taverna Geek: dados de RPG, board games, camisetas e mouses, teclados, headsets e notebooks gamers incríveis.">
  <link rel="stylesheet" href="css/style.css">
</head>
<body>

  <!-- ==========================================================================
     CSS HACKS - CONTROLES DE ESTADO (CHECKBOXES E RÁDIOS)
     ========================================================================== -->
  <!-- Checkbox para abrir/fechar o carrinho lateral -->
  <input type="checkbox" id="cart-toggle" class="state-toggle">
  <!-- Checkbox para abrir/fechar o modal de login/registro -->
  <input type="checkbox" id="auth-toggle" class="state-toggle">

  <!-- Rádios para filtragem do Catálogo (Devem estar antes do Grid de Produtos no DOM) -->
  <input type="radio" id="filter-all" name="prod-filter" class="state-toggle" checked>
  <input type="radio" id="filter-rpg" name="prod-filter" class="state-toggle">
  <input type="radio" id="filter-perifericos" name="prod-filter" class="state-toggle">
  <input type="radio" id="filter-camisas" name="prod-filter" class="state-toggle">
  <input type="radio" id="filter-jogos" name="prod-filter" class="state-toggle">

  <!-- Cabeçalho Principal -->
  <header>
    <a href="index.html" class="logo">
      🎲 <span>Taverna Geek</span>
    </a>

    <nav>
      <a href="index.html">Início</a>
      <a href="produtos.html" class="active">Produtos</a>
      <a href="sobre.html">Sobre Nós</a>
      <a href="contato.html">Contato</a>
    </nav>

    <div class="header-actions">
      <label for="auth-toggle" class="icon-badge-btn" title="Minha Conta">👤</label>
      <label for="cart-toggle" class="icon-badge-btn" title="Meu Carrinho">
        🛒 <span class="badge">3</span>
      </label>
    </div>
  </header>

  <!-- ==========================================================================
     INTERATIVIDADE CSS: CARRINHO DE COMPRAS DESLIZANTE
     ========================================================================== -->
  <div class="cart-overlay"></div>
  <aside class="cart-sidebar">
    <div class="cart-header">
      <h3>🛒 Seu Carrinho</h3>
      <label for="cart-toggle" class="cart-close">&times;</label>
    </div>

    <div class="cart-items-container">
      <!-- Item 1 -->
      <div class="cart-item">
        <div class="cart-item-img">
          <img src="img/dados.jpg" alt="Dados de RPG">
        </div>
        <div class="cart-item-info">
          <h4>Dados de RPG Runas Douradas</h4>
          <p>Categoria: RPG & Acessórios</p>
          <div class="cart-item-qty">
            <span>Qtd: 1</span>
            <span class="price">R$ 89,90</span>
          </div>
        </div>
        <button class="cart-item-remove">&times;</button>
      </div>

      <!-- Item 2 -->
      <div class="cart-item">
        <div class="cart-item-img">
          <img src="img/headset.jpg" alt="Headset Gamer">
        </div>
        <div class="cart-item-info">
          <h4>Headset Gamer CyberGlow RGB</h4>
          <p>Categoria: Periféricos</p>
          <div class="cart-item-qty">
            <span>Qtd: 1</span>
            <span class="price">R$ 349,90</span>
          </div>
        </div>
        <button class="cart-item-remove">&times;</button>
      </div>

      <!-- Item 3 -->
      <div class="cart-item">
        <div class="cart-item-img">
          <img src="img/camisa.jpg" alt="Camiseta Geek">
        </div>
        <div class="cart-item-info">
          <h4>Camiseta Geek Vaporwave Arcade</h4>
          <p>Categoria: Vestuário</p>
          <div class="cart-item-qty">
            <span>Qtd: 1</span>
            <span class="price">R$ 79,90</span>
          </div>
        </div>
        <button class="cart-item-remove">&times;</button>
      </div>
    </div>

    <div class="cart-footer">
      <div class="cart-total-row">
        <span>Subtotal:</span>
        <span>R$ 519,70</span>
      </div>
      <a href="#checkout-form" class="btn" style="width:100%;" onclick="document.getElementById('cart-toggle').checked = false;">
        💳 Ir para o Checkout
      </a>
    </div>
  </aside>

  <!-- ==========================================================================
     INTERATIVIDADE CSS: MODAL DE LOGIN/REGISTRO
     ========================================================================== -->
  <div class="modal-overlay">
    <div class="auth-card">
      <div class="auth-header">
        <h3 style="margin:0; font-size:1.3rem;">🛡️ Área do Taverneiro</h3>
        <label for="auth-toggle" style="cursor:pointer; font-size:1.5rem; color:var(--text-muted);">&times;</label>
      </div>

      <input type="radio" id="auth-tab-login" name="auth-tabs" class="state-toggle" checked>
      <input type="radio" id="auth-tab-register" name="auth-tabs" class="state-toggle">

      <div class="auth-tabs-nav">
        <label for="auth-tab-login" class="auth-tab-label">Iniciar Sessão</label>
        <label for="auth-tab-register" class="auth-tab-label">Registrar Guilda</label>
      </div>

      <form class="auth-form-block form-login" action="#" method="POST" onsubmit="return false;">
        <div style="display:flex; flex-direction:column; gap:6px;">
          <label style="font-size:0.85rem; color:var(--text-muted);">Seu E-mail de Mago</label>
          <input type="email" placeholder="nome@guilda.com" required>
        </div>
        <div style="display:flex; flex-direction:column; gap:6px;">
          <label style="font-size:0.85rem; color:var(--text-muted);">Senha Secreta</label>
          <input type="password" placeholder="••••••••" required>
        </div>
        <button type="submit" class="btn">Entrar na Taverna</button>
      </form>

      <form class="auth-form-block form-register" action="#" method="POST" onsubmit="return false;">
        <div style="display:flex; flex-direction:column; gap:6px;">
          <label style="font-size:0.85rem; color:var(--text-muted);">Nome de Usuário</label>
          <input type="text" placeholder="Ex: Legolas" required>
        </div>
        <div style="display:flex; flex-direction:column; gap:6px;">
          <label style="font-size:0.85rem; color:var(--text-muted);">E-mail de Contato</label>
          <input type="email" placeholder="mestre@caverna.com" required>
        </div>
        <button type="submit" class="btn btn-secondary">📜 Concluir Cadastro</button>
      </form>
    </div>
  </div>

  <!-- CONTEÚDO PRINCIPAL -->
  <main>
    <div style="margin-bottom:30px;">
      <h1 style="margin:0 0 10px 0; font-size:2.5rem; font-weight:800;">Masmorra de <span>Itens</span></h1>
      <p style="margin:0; color:var(--text-muted);">Filtre os baús por categoria e equipe seus personagens com os melhores loots do reino.</p>
    </div>

    <!-- Layout do Catálogo (Filtro Lateral + Grid) -->
    <div class="catalog-layout">
      
