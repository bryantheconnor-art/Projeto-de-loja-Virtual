            <label style="font-size:0.85rem; color:var(--text-muted); font-weight:700;">Avalie este Item:</label>
            <div class="interactive-stars">
              <input type="radio" id="star5-camisa" name="rating-camisa" value="5"><label for="star5-camisa">★</label>
              <input type="radio" id="star4-camisa" name="rating-camisa" value="4"><label for="star4-camisa">★</label>
              <input type="radio" id="star3-camisa" name="rating-camisa" value="3"><label for="star3-camisa">★</label>
              <input type="radio" id="star2-camisa" name="rating-camisa" value="2"><label for="star2-camisa">★</label>
