          <ul class="filter-list">
            <li class="filter-item">
              <label for="filter-all" class="filter-label">🔮 Todos os Itens</label>
            </li>
            <li class="filter-item">
              <label for="filter-rpg" class="filter-label">🐉 Aventuras de RPG</label>
            </li>
            <li class="filter-item">
              <label for="filter-perifericos" class="filter-label">⚡ Arsenal Gamer (Periféricos)</label>
            </li>
            <li class="filter-item">
              <label for="filter-camisas" class="filter-label">👕 Vestuário Geek</label>
            </li>
            <li class="filter-item">
              <label for="filter-jogos" class="filter-label">🏰 Jogos de Tabuleiro</label>
            </li>
          </ul>
        </div>

