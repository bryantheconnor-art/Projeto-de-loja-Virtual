            </div>
          </div>
        </article>

        <!-- CARD DO PRODUTO 2: Camiseta Arcade (camisa.jpg) -->
        <article class="product-card cat-camisas">
          <div class="product-img-wrapper">
            <span class="product-badge badge-new">Novidade</span>
            <img src="img/camisa.jpg" alt="Camiseta Geek Arcade">
