            </div>
          </div>
        </article>

        <!-- CARD DO PRODUTO 3: Headset Gamer (headset.jpg) -->
        <article class="product-card cat-perifericos">
          <div class="product-img-wrapper">
            <span class="product-badge badge-promo">Oferta</span>
            <img src="img/headset.jpg" alt="Headset Gamer CyberGlow">
          </div>
          <div class="product-info">
            <span class="product-cat">Arsenal Gamer</span>
            <a href="#detail-headset" class="product-title">Headset Gamer Wireless CyberGlow Pro Surround 7.1</a>
            <div class="rating-stars">
              ⭐⭐⭐⭐⭐ <span class="rating-count">(87)</span>
            </div>
            <div class="product-price-row">
              <div class="price-container">
                <span class="old-price">R$ 450,00</span>
                <span class="current-price">R$ 349,90</span>
              </div>
              <a href="#detail-headset" class="btn btn-secondary" style="padding: 8px 16px; font-size: 0.85rem;">🛡️ Detalhes</a>
            </div>
          </div>
        </article>

        <!-- CARD DO PRODUTO 4: Jogo de Tabuleiro (jogo.jpg) -->
        <article class="product-card cat-jogos">
          <div class="product-img-wrapper">
            <img src="img/jogo.jpg" alt="Jogo de Tabuleiro Dragon Quest">
          </div>
          <div class="product-info">
            <span class="product-cat">Jogos de Tabuleiro</span>
            <a href="#detail-jogo" class="product-title">Board Game Clássico - Crônicas da Montanha do Dragão</a>
            <div class="rating-stars">
              ⭐⭐⭐⭐★ <span class="rating-count">(31)</span>
            </div>
            <div class="product-price-row">
              <div class="price-container">
                <span class="current-price">R$ 289,90</span>
              </div>
              <a href="#detail-jogo" class="btn btn-secondary" style="padding: 8px 16px; font-size: 0.85rem;">🛡️ Detalhes</a>
            </div>
          </div>
        </article>

        <!-- CARD DO PRODUTO 5: Notebook Gamer (notebook.jpg) - EXIGIDO NA FOTO -->
        <article class="product-card cat-perifericos">
          <div class="product-img-wrapper">
            <span class="product-badge badge-promo">Epic Loot</span>
            <img src="img/notebook.jpg" alt="Notebook Gamer Supernova">
          </div>
          <div class="product-info">
            <span class="product-cat">Arsenal Gamer</span>
            <a href="#detail-notebook" class="product-title">Notebook Gamer Supernova Pro - RTX 4080, Ryzen 9</a>
            <div class="rating-stars">
              ⭐⭐⭐⭐⭐ <span class="rating-count">(11)</span>
            </div>
            <div class="product-price-row">
              <div class="price-container">
                <span class="old-price">R$ 12.990,00</span>
                <span class="current-price">R$ 10.499,90</span>
              </div>
              <a href="#detail-notebook" class="btn btn-secondary" style="padding: 8px 16px; font-size: 0.85rem;">🛡️ Detalhes</a>
            </div>
          </div>
        </article>

        <!-- CARD DO PRODUTO 6: Mouse Gamer (mouse.jpg) - EXIGIDO NA FOTO -->
        <article class="product-card cat-perifericos">
          <div class="product-img-wrapper">
            <img src="img/mouse.jpg" alt="Mouse Gamer Hyperion">
          </div>
          <div class="product-info">
            <span class="product-cat">Arsenal Gamer</span>
            <a href="#detail-mouse" class="product-title">Mouse Gamer Hyperion UltraLight - 26k DPI, Sensor Rúnico</a>
            <div class="rating-stars">
              ⭐⭐⭐⭐⭐ <span class="rating-count">(53)</span>
            </div>
            <div class="product-price-row">
              <div class="price-container">
                <span class="current-price">R$ 219,90</span>
              </div>
              <a href="#detail-mouse" class="btn btn-secondary" style="padding: 8px 16px; font-size: 0.85rem;">🛡️ Detalhes</a>
            </div>
          </div>
        </article>

      </section>
    </div>

    <!-- ==========================================================================
       MODAIS DE DETALHE DOS PRODUTOS (:target HACKS 100% CSS)
       ========================================================================== -->
    
    <!-- Modal 1: Dados RPG -->
    <div id="detail-dados" class="detail-modal">
      <div class="detail-card">
        <a href="#store-catalog" class="detail-close">&times;</a>
        <div class="detail-gallery">
          <img src="img/dados.jpg" alt="Dados RPG Místicos">
        </div>
        <div class="detail-body">
          <span class="product-cat">RPG & Acessórios</span>
          <h2>Dados RPG Runas Douradas</h2>
          <p class="description">Forjados no fogo das montanhas profundas do reino, este conjunto completo de 7 dados poliédricos (D4 a D20) é feito de obsidian acrílico e pintado com runas élficas douradas. Garantia de acertos críticos naturais.</p>
          <div class="detail-specs">
            <h4>Especificações Técnicas</h4>
            <ul>
              <li>Material: Obsidian Acrílico</li>
              <li>Quantidade: Set com 7 dados</li>
              <li>Estilo: Runas Élficas</li>
              <li>Brilha na Luz Negra: Sim</li>
            </ul>
          </div>
          <div style="font-weight:700; color:var(--color-secondary); font-size:1.6rem; margin-bottom:20px;">R$ 89,90</div>
          
          <!-- Formulário de Avaliação Interno Estrelas -->
          <form action="#" method="POST" onsubmit="return false;" style="padding:15px; border:1px solid var(--border-color); background:none; margin-bottom:20px; gap:8px;">
            <label style="font-size:0.85rem; color:var(--text-muted); font-weight:700;">Avalie este Item:</label>
            <div class="interactive-stars">
              <input type="radio" id="star5-dados" name="rating-dados" value="5"><label for="star5-dados">★</label>
              <input type="radio" id="star4-dados" name="rating-dados" value="4"><label for="star4-dados">★</label>
              <input type="radio" id="star3-dados" name="rating-dados" value="3"><label for="star3-dados">★</label>
              <input type="radio" id="star2-dados" name="rating-dados" value="2"><label for="star2-dados">★</label>
              <input type="radio" id="star1-dados" name="rating-dados" value="1"><label for="star1-dados">★</label>
            </div>
            <textarea placeholder="Deixe seu pergaminho de feedback..." style="height:60px; padding:8px; font-size:0.8rem;"></textarea>
            <button type="submit" class="btn" style="padding:6px 12px; font-size:0.8rem; width:fit-content; margin-top:5px;">⭐ Enviar Avaliação</button>
          </form>

          <a href="#store-catalog" class="btn" style="width:100%;">⚔️ Colocar na Mochila (Comprar)</a>
        </div>
      </div>
    </div>

    <!-- Modal 2: Camiseta Arcade -->
