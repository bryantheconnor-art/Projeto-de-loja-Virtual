            </li>
            <li class="filter-item">
              <input type="checkbox" id="status-stock" checked style="margin-right:10px;">
              <label for="status-stock" class="filter-label">Em Estoque</label>
            </li>
          </ul>
        </div>
      </aside>

      <!-- Grid de Exibição dos Produtos -->
      <section class="products-grid">
        
        <!-- CARD DO PRODUTO 1: Dados RPG (dados.jpg) -->
        <article class="product-card cat-rpg">
