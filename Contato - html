<!DOCTYPE html>
<html lang="pt-BR">

<head>

    <!-- Configurações básicas -->
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">

    <!-- Título do site -->
    <title>Contato | YoshiTudo</title>

    <!-- CSS -->
    <link rel="stylesheet" href="estilos/geral.css">
    <link rel="stylesheet" href="estilos/contato.css">

</head>

<body>

    <!-- ========================= -->
    <!-- CABEÇALHO / MENU -->
    <!-- ========================= -->

    <header class="cabecalho">

        <!-- Logo -->
        <a href="index.html" class="logotipo">
            ⚡ YoshiTudo 
        </a>

        <!-- Menu -->
        <nav class="menu">

            <a href="index.html">Início</a>
            <a href="produtos.html">Produtos</a>
            <a href="sobre.html">Sobre</a>
            <a href="contato.html" class="ativo">Contato</a>

        </nav>

    </header>

    <!-- ========================= -->
    <!-- TÍTULO DA PÁGINA -->
    <!-- ========================= -->

    <section class="titulo-pagina">

        <h1>📞 Fale com a gente</h1>

        <p>
            Tire suas dúvidas, peça informações ou mande uma sugestão.
        </p>

    </section>

    <!-- ========================= -->
    <!-- CONTATO -->
    <!-- ========================= -->

    <main class="pagina-contato">

        <!-- Informações -->
        <section class="informacoes-contato">

            <h2>Informações da loja</h2>

            <p>
                📍 Av. castroconnorsilva - Fatecanos- SP
            </p>

            <p>
                🕒 Aberto todos os dias das 10h às 19h
            </p>

            <p>
                📧 contato@yoshitudo.com.br
            </p>

            <p>
                💬 WhatsApp:
                <a href="https://wa.me/5511999999999" target="_blank" class="link-whatsapp">
                    <img src="marcas/whatsapp.svg" alt="WhatsApp" class="icone-whatsapp">
                    <span>(11) 99999-9999</span>
                </a>
            </p>

            <!-- Mapa: Tag iframe usada para incorporar de forma segura o mapa do Google Maps na página -->
            <div class="mapa">

                <iframe src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3658.1110244917977!2d-47.13630302467088!3d-23.528508878822475!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x94cf0d55820f0aa9%3A0x45c066f7a375456a!2sYOSHITEC%20ELETRONICOS!5e0!3m2!1spt-BR!2sbr!4v1780077567970!5m2!1spt-BR!2sbr" allowfullscreen="" loading="lazy" referrerpolicy="no-referrer-when-downgrade"></iframe>

            </div>

        </section>

        <!-- Formulário de Contato -->
        <section class="formulario-contato">

            <h2>Enviar mensagem</h2>

            <!-- Tag form: Agrupa os campos de entrada de dados. Possui action apontando para o WhatsApp API, method "get" e target "_blank" para abrir em nova aba -->
            <form id="contato-whatsapp" action="https://api.whatsapp.com/send" method="get" target="_blank">
                
                <!-- Input oculto: Define o número de telefone de destino do WhatsApp -->
                <input type="hidden" name="phone" value="5511995099712">
                
                <!-- Input oculto: Guardará a mensagem final estruturada pelo Javascript -->
                <input type="hidden" name="text" id="mensagem-completa">

                <!-- Label e Input do Nome: Recebe o nome do cliente. O atributo 'required' torna o preenchimento obrigatório -->
                <label for="nome">Nome</label>
                <input type="text" id="nome" placeholder="Seu nome" required>

                <!-- Label e Input do E-mail: Recebe o e-mail do cliente, validando o formato com type="email" -->
                <label for="email">E-mail</label>
                <input type="email" id="email" placeholder="Seu e-mail" required>

                <!-- Label e Select de Assunto: Menu de seleção suspensa para categorizar o contato -->
                <label for="categoria">Assunto</label>
                <select id="categoria" required>
                    <option value="">Selecione um assunto</option>
                    <option value="informacões sobre produtos">Informações sobre produtos</option>
                    <option value="ajuda com um pedido">Ajuda com um pedido</option>
                    <option value="suporte">Suporte</option>
                    <option value="enviar uma sugestão">Enviar uma sugestão</option>
                </select>

                <!-- Label e Textarea de Mensagem: Caixa de texto de múltiplas linhas para a mensagem livre -->
                <label for="mensagem">Mensagem</label>
                <textarea id="mensagem" placeholder="Digite sua mensagem" required></textarea>

                <!-- Botão de Envio: Dispara a submissão e validação do formulário ao ser clicado -->
                <button type="submit" class="botao">
                    Enviar
                </button>

            </form>

        </section>

    </main>

    <!-- ========================= -->
    <!-- RODAPÉ -->
    <!-- ========================= -->

    <footer class="rodape">

        <div class="conteudo-rodape">

            <div class="coluna-rodape">
                <h4>LOCALIZAÇÃO</h4>
                <p>Av. CastroConoorSilva </p>
                <p>Fatecanos - SP </p>
            </div>

            <div class="coluna-rodape">
                <h4>CONTATO E REDES SOCIAIS</h4>

                <div class="links-sociais">
                    <a href="https://www.facebook.com/" target="_blank" class="botao-social" aria-label="Facebook">
                        <img src="marcas/facebook.svg" alt="Facebook">
                    </a>

                    <a href="https://www.instagram.com/" target="_blank" class="botao-social" aria-label="Instagram">
                        <img src="marcas/instagram.svg" alt="Instagram">
                    </a>

                    <a href="https://www.youtube.com/" target="_blank" class="botao-social" aria-label="YouTube">
                        <img src="marcas/youtube.svg" alt="YouTube">
                    </a>

                    <a href="https://wa.me/5511999999999" target="_blank" class="botao-social" aria-label="WhatsApp">
                        <img src="marcas/whatsapp.svg" alt="WhatsApp">
                    </a>
                </div>
            </div>

            <div class="coluna-rodape">
                <p class="mensagem-rodape">
                    Nós te ajudamos! Entre em contato através de nossas redes sociais.
                </p>
            </div>

        </div>

        <p class="direitos">
            Copyright © <span>YoshiTudo</span> 2026
        </p>

    </footer>

    <!-- Script interno para realizar a validação dos campos e a formatação da mensagem que será enviada -->
    <script>
        // Função responsável por validar o formulário e formatar a mensagem que será enviada
        function enviarMensagem(event) {
            // Obtém a referência do elemento do formulário de contato
            const formulario = document.getElementById("contato-whatsapp")
            // Obtém a referência do campo de texto oculto que armazenará a mensagem formatada completa
            const mensagemCompleta = document.getElementById("mensagem-completa")

            // Verifica se os elementos do formulário e do campo de mensagem existem na página; se não existirem, aborta a execução
            if (!formulario || !mensagemCompleta) {
                return false
            }

            // Verifica se todos os campos obrigatórios do formulário foram preenchidos corretamente
            if (!formulario.checkValidity()) {
                // Se houver um evento associado (como submit), cancela o comportamento padrão do envio (evita recarregar a página)
                if (event) {
                    event.preventDefault()
                }

                // Exibe os alertas visuais de validação nativos do navegador nos campos incorretos
                formulario.reportValidity()
                return false
            }

            // Obtém as referências dos campos de entrada de dados do usuário
            const nome = document.getElementById("nome")
            const email = document.getElementById("email")
            const categoria = document.getElementById("categoria")
            const mensagem = document.getElementById("mensagem")

            // Monta o texto formatado no campo oculto 'mensagemCompleta' usando os valores preenchidos pelo usuário
            mensagemCompleta.value =
                `Meu nome é ${nome.value}.
                Meu e-mail é ${email.value}.
                Estou entrando em contato pois preciso de ${categoria.value}.
                Mais informacões:
                ${mensagem.value}`

            // Retorna verdadeiro para indicar que a validação e formatação foram concluídas com sucesso
            return true
        }

        // Adiciona um ouvinte para executar o código assim que a estrutura do documento HTML for completamente carregada
        document.addEventListener("DOMContentLoaded", function () {
            // Obtém a referência do formulário de contato
            const formulario = document.getElementById("contato-whatsapp")

            // Caso o formulário esteja presente na página atual, adiciona o evento de envio ('submit') chamando a função enviarMensagem
            if (formulario) {
                formulario.addEventListener("submit", enviarMensagem)
            }
        })
    </script>

</body>

</html>

